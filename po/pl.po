#: src/power.c:96
msgid ""
"This power supply is not capable of supplying 5A\n"
"Power to peripherals will be restricted"
msgstr ""
"Zasilacz nie jest w stanie dostarczyć 5A\n"
"Zasilanie urządzeń peryferyjnych zostanie ograniczone"

#: src/power.c:112
msgid ""
"Reset due to low power event\n"
"Please check your power supply"
msgstr ""
"Restart spowodowany zbyt niskim napięciem\n"
"Sprawdź zasilacz"

#: src/power.c:186
msgid ""
"High display resolution is using large amounts of memory.\n"
"Consider reducing screen resolution."
msgstr ""
"Wysoka rozdzielczość ekranu zużywa dużą ilość pamięci.\n"
"Rozważ obniżenie rozdzielczości."

#: src/power.c:198
msgid ""
"Drawing the desktop is using large amounts of memory\n"
"Consider disabling active desktop"
msgstr ""
"Renderowanie pulpitu zużywa dużą ilość pamięci\n"
"Rozważ wyłączenie aktywnego pulpitu"

#: src/power.c:248
msgid ""
"USB overcurrent\n"
"Please check your connected USB devices"
msgstr ""
"Przeciążenie portu USB\n"
"Sprawdź podłączone urządzenia USB"

#: src/power.c:282
msgid ""
"Low voltage warning\n"
"Please check your power supply"
msgstr ""
"Ostrzeżenie o niskim napięciu\n"
"Sprawdź zasilacz"

#: src/power.c:309
msgid "PSU low voltage detected\n"
msgstr "Wykryto niskie napięcie zasilacza\n"

#: src/power.c:310
msgid "USB over current detected\n"
msgstr "Wykryto przeciążenie portu USB\n"

#: src/power.c:311
msgid "Low power reset has occurred\n"
msgstr "Wystąpił reset spowodowany niskim napięciem\n"

#: src/power.c:367
msgid "Power Information..."
msgstr "Informacje o zasilaniu…"

#: src/power.c:465
msgid "Monitors system power"
msgstr "Monitoruje stan zasilania systemu"

